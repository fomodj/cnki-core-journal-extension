{
  "manifest_version": 3,
  "name": "核心期刊多库标注（2025-2026）",
  "version": "1.2.0",
  "description": "在知网搜索结果页自动标注 CSSCI (2025-2026)/ 北大核心(2023) / AMI (2022)/ 国家社科基金(2025)等多数据库核心期刊。数据集来自万维书刊网2026-05-23。",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.cnki.net/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.cnki.net/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "核心期刊多库标注"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/core_plugin_data.json"
      ],
      "matches": [
        "*://*.cnki.net/*"
      ]
    }
  ]
}